
---
---

<div
    class="modal-overlay"
    id="registration-modal"
    x-data="{ open: false }"
    @open-modal.window="open = true; document.body.style.overflow = 'hidden'"
    @keydown.escape.window="open = false; document.body.style.overflow = 'auto'"
    :class="open ? 'active' : ''"
    @click="if ($event.target === $el) { open = false; document.body.style.overflow = 'auto' }"
>
    <div class="modal-content">
        <h3 class="modal-title">Требуется регистрация</h3>
        <p class="modal-text">Для доступа к расширенным настройкам необходимо зарегистрироваться в системе GameHub.</p>
        <div class="modal-buttons">
            <button class="modal-button modal-cancel" @click="open = false; document.body.style.overflow = 'auto'">Отмена</button>
            <button class="modal-button modal-register" @click="open = false; document.body.style.overflow = 'auto'; window.location.href = '/register'">Зарегистрироваться</button>
        </div>
    </div>
</div>
